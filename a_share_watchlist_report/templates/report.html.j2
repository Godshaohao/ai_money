<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>A-share Watchlist Report</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f6f8fb;
      --paper: #ffffff;
      --paper-soft: #fbfcfe;
      --ink: #172033;
      --muted: #617089;
      --subtle: #8a96aa;
      --line: #dbe3ee;
      --line-strong: #bfccd9;
      --header: #0f172a;
      --header-2: #182235;
      --accent: #0f766e;
      --accent-soft: #e0f5f1;
      --good: #147d50;
      --good-soft: #e0f7ea;
      --warn: #9a5b00;
      --warn-soft: #fff3d6;
      --bad: #b42318;
      --bad-soft: #ffe4e0;
      --focus: #2563eb;
      --shadow: 0 12px 32px rgba(23, 32, 51, 0.08);
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      color: var(--ink);
      background: var(--bg);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      letter-spacing: 0;
    }
    a { color: inherit; text-decoration: none; }
    .topbar {
      position: sticky;
      top: 0;
      z-index: 20;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      min-height: 58px;
      padding: 0 22px;
      color: #e5edf7;
      background: var(--header);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 11px;
      min-width: 240px;
      font-weight: 800;
    }
    .brand-mark {
      display: grid;
      place-items: center;
      width: 34px;
      height: 34px;
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 7px;
      color: #8af0d2;
      background: var(--header-2);
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: 13px;
    }
    .topnav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
      flex: 1;
      overflow-x: auto;
    }
    .topnav a {
      flex: 0 0 auto;
      padding: 8px 10px;
      border-radius: 7px;
      color: #c8d3e1;
      font-size: 13px;
    }
    .topnav a:hover { background: rgba(255, 255, 255, 0.08); color: #ffffff; }
    .run-time {
      min-width: 178px;
      color: #aab8ca;
      font-size: 12px;
      text-align: right;
    }
    main {
      max-width: 1520px;
      margin: 0 auto;
      padding: 20px 22px 32px;
    }
    .dashboard-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 340px;
      gap: 16px;
      margin-bottom: 14px;
    }
    .title-panel,
    .health-panel,
    .query-bar,
    .panel {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 8px;
      box-shadow: var(--shadow);
    }
    .title-panel {
      padding: 20px 22px;
    }
    .eyebrow {
      margin: 0 0 8px;
      color: var(--accent);
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
    }
    h1 {
      margin: 0;
      font-size: 28px;
      line-height: 1.16;
      letter-spacing: 0;
    }
    .title-copy {
      max-width: 780px;
      margin: 10px 0 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.55;
    }
    .health-panel {
      display: grid;
      align-content: center;
      gap: 12px;
      padding: 18px;
    }
    .status-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }
    .status-row span:first-child {
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
    }
    .badge {
      display: inline-flex;
      align-items: center;
      min-height: 24px;
      padding: 3px 9px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 800;
      white-space: nowrap;
    }
    .badge.good { color: var(--good); background: var(--good-soft); }
    .badge.warn { color: var(--warn); background: var(--warn-soft); }
    .badge.bad { color: var(--bad); background: var(--bad-soft); }
    .query-bar {
      display: grid;
      grid-template-columns: repeat(4, minmax(140px, 1fr));
      gap: 0;
      margin-bottom: 14px;
      overflow: hidden;
    }
    .query-item {
      min-height: 66px;
      padding: 12px 14px;
      border-right: 1px solid var(--line);
      background: var(--paper-soft);
    }
    .query-item:last-child { border-right: 0; }
    .query-item span {
      display: block;
      color: var(--subtle);
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
    }
    .query-item strong {
      display: block;
      margin-top: 6px;
      font-size: 15px;
      overflow-wrap: anywhere;
    }
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(6, minmax(140px, 1fr));
      gap: 12px;
      margin-bottom: 14px;
    }
    .metric {
      min-height: 104px;
      padding: 14px;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 8px;
      box-shadow: var(--shadow);
    }
    .metric span {
      display: block;
      min-height: 28px;
      color: var(--muted);
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
    }
    .metric strong {
      display: block;
      margin-top: 8px;
      font-size: 26px;
      line-height: 1.1;
      overflow-wrap: anywhere;
    }
    .metric .hint {
      margin-top: 7px;
      color: var(--subtle);
      font-size: 12px;
    }
    .layout-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.85fr);
      gap: 14px;
      align-items: start;
    }
    .stack {
      display: grid;
      gap: 14px;
    }
    .panel { overflow: hidden; }
    .panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      min-height: 54px;
      padding: 14px 16px;
      border-bottom: 1px solid var(--line);
      background: linear-gradient(#ffffff, #fbfcfe);
    }
    .panel-title {
      display: flex;
      align-items: baseline;
      gap: 10px;
      min-width: 0;
    }
    h2 {
      margin: 0;
      font-size: 15px;
      letter-spacing: 0;
    }
    .panel-note {
      color: var(--subtle);
      font-size: 12px;
      text-align: right;
    }
    .panel-body {
      padding: 14px 16px;
    }
    .alert {
      margin: 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.55;
      overflow-wrap: anywhere;
    }
    .alert strong { color: var(--ink); }
    .table-wrap {
      width: 100%;
      overflow-x: auto;
    }
    table {
      width: 100%;
      min-width: 780px;
      border-collapse: collapse;
      font-size: 12px;
    }
    th,
    td {
      padding: 9px 10px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
    }
    th {
      position: sticky;
      top: 0;
      z-index: 1;
      color: var(--muted);
      background: #f0f4f9;
      font-size: 10px;
      font-weight: 900;
      text-transform: uppercase;
      white-space: nowrap;
    }
    tbody tr:hover { background: #f8fbff; }
    .num { text-align: right; font-variant-numeric: tabular-nums; }
    .mono {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-variant-numeric: tabular-nums;
    }
    .reason {
      min-width: 280px;
      color: #334155;
      line-height: 1.45;
    }
    .empty {
      padding: 18px 16px;
      color: var(--muted);
      background: #fbfcfe;
      font-size: 13px;
    }
    pre {
      margin: 0;
      padding: 14px 16px;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      color: #d7e4f2;
      background: #0f172a;
      font-size: 12px;
      line-height: 1.55;
    }
    @media (max-width: 1180px) {
      .dashboard-head,
      .layout-grid {
        grid-template-columns: 1fr;
      }
      .summary-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
    @media (max-width: 820px) {
      .topbar {
        position: static;
        display: block;
        padding: 12px;
      }
      .topnav {
        justify-content: flex-start;
        margin-top: 10px;
      }
      .run-time {
        margin-top: 8px;
        text-align: left;
      }
      main { padding: 12px; }
      .query-bar,
      .summary-grid {
        grid-template-columns: 1fr 1fr;
      }
    }
    @media (max-width: 560px) {
      .query-bar,
      .summary-grid {
        grid-template-columns: 1fr;
      }
      h1 { font-size: 24px; }
      .panel-head {
        display: block;
      }
      .panel-note {
        margin-top: 6px;
        text-align: left;
      }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="brand"><div class="brand-mark">A</div><div>A-share Workbench</div></div>
    <nav class="topnav" aria-label="Dashboard sections">
      <a href="#overview">Overview</a>
      <a href="#market">Market</a>
      <a href="#watchlist">Watchlist</a>
      <a href="#dragon-tiger">Dragon Tiger</a>
      <a href="#excluded">Exclusions</a>
      <a href="#holding-risk">Holdings</a>
      <a href="#quality">Quality</a>
    </nav>
    <div class="run-time">Generated {{ generated_at }}</div>
  </header>

  <main>
    <section id="overview" class="dashboard-head" aria-label="Dashboard overview">
      <div class="title-panel">
        <p class="eyebrow">Static local research dashboard</p>
        <h1>A-share Watchlist Report</h1>
        <p class="title-copy">A compact, review-first dashboard for market regime, watchlist candidates, today&apos;s Dragon Tiger List, exclusions, holdings, and data quality. Outputs are observation aids only.</p>
      </div>
      <div class="health-panel">
        <div class="status-row"><span>Data source</span><span class="badge {{ data_source_kind }}">{{ data_source_status }}</span></div>
        <div class="status-row"><span>Market regime</span><span class="badge {{ market_regime_kind }}">{{ market_regime }}</span></div>
        <div class="status-row"><span>Risk exposure review</span><span class="badge {{ risk_exposure_kind }}">{{ risk_exposure_review }}</span></div>
      </div>
    </section>

    <section class="query-bar" aria-label="Run context">
      <div class="query-item"><span>Data provider</span><strong>AKShare / EastMoney</strong></div>
      <div class="query-item"><span>Latest Dragon Tiger date</span><strong>{{ latest_dragon_tiger_date }}</strong></div>
      <div class="query-item"><span>Universe mode</span><strong>Watchlist + LHB, capped at config</strong></div>
      <div class="query-item"><span>Output mode</span><strong>Static HTML + CSV</strong></div>
    </section>

    <section class="summary-grid" aria-label="Key metrics">
      <div class="metric"><span>Watchlist candidates</span><strong>{{ watchlist_count }}</strong><div class="hint">Ranked observations</div></div>
      <div class="metric"><span>Dragon tiger rows</span><strong>{{ dragon_tiger_count }}</strong><div class="hint">Today&apos;s LHB records</div></div>
      <div class="metric"><span>Excluded stocks</span><strong>{{ excluded_count }}</strong><div class="hint">Hard filters</div></div>
      <div class="metric"><span>Holding risks</span><strong>{{ holding_risk_count }}</strong><div class="hint">Manual review flags</div></div>
      <div class="metric"><span>Market regime</span><strong>{{ market_regime }}</strong><div class="hint">Index evidence</div></div>
      <div class="metric"><span>Data source</span><strong>{{ data_source_status }}</strong><div class="hint">Live or cache</div></div>
    </section>

    <div class="layout-grid">
      <div class="stack">
        <section id="market" class="panel">
          <div class="panel-head">
            <div class="panel-title"><h2>Market regime</h2><span class="badge {{ market_regime_kind }}">{{ market_regime }}</span></div>
            <div class="panel-note">Index trend evidence</div>
          </div>
          {% if market_evidence %}
          <div class="table-wrap">
            <table>
              <thead><tr><th>Index</th><th class="num">Close</th><th class="num">MA200</th><th>Above MA200</th><th class="num">20D Return</th><th>Status</th></tr></thead>
              <tbody>
                {% for row in market_evidence %}
                <tr><td>{{ row.index_name }}</td><td class="num">{{ row.close }}</td><td class="num">{{ row.ma200 }}</td><td>{{ row.above_ma200 }}</td><td class="num">{{ row.return_20d }}</td><td><span class="badge {% if row.status == 'POSITIVE' %}good{% elif row.status == 'NEGATIVE' %}bad{% else %}warn{% endif %}">{{ row.status }}</span></td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% else %}<div class="empty">Market regime evidence is unavailable.</div>{% endif %}
        </section>

        <section id="watchlist" class="panel">
          <div class="panel-head">
            <div class="panel-title"><h2>Watchlist Top 20</h2><span class="badge warn">Observation</span></div>
            <div class="panel-note">Observation only; no trade instruction</div>
          </div>
          {% if watchlist %}
          <div class="table-wrap">
            <table>
              <thead><tr><th>Rank</th><th>Symbol</th><th>Name</th><th>Industry</th><th class="num">Close</th><th class="num">12M Momentum</th><th class="num">6M Momentum</th><th>Reason</th></tr></thead>
              <tbody>
                {% for row in watchlist %}
                <tr><td class="mono">{{ row.rank }}</td><td class="mono">{{ row.symbol }}</td><td>{{ row.name }}</td><td>{{ row.industry }}</td><td class="num">{{ row.close }}</td><td class="num">{{ row.momentum_12m }}</td><td class="num">{{ row.momentum_6m }}</td><td class="reason">{{ row.reason }}</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% else %}<div class="empty">No watchlist candidates were generated for the current run.</div>{% endif %}
        </section>

        <section id="dragon-tiger" class="panel">
          <div class="panel-head">
            <div class="panel-title"><h2>Dragon Tiger List</h2><span class="badge warn">{{ dragon_tiger_count }} rows</span></div>
            <div class="panel-note">Today&apos;s EastMoney LHB stocks added to the observation universe</div>
          </div>
          {% if dragon_tiger %}
          <div class="table-wrap">
            <table>
              <thead><tr><th>Date</th><th>Symbol</th><th>Name</th><th class="num">Close</th><th class="num">Change</th><th class="num">Net Buy</th><th class="num">Buy</th><th class="num">Sell</th><th class="num">Deal</th><th class="num">Turnover</th><th>Reason</th></tr></thead>
              <tbody>
                {% for row in dragon_tiger %}
                <tr><td>{{ row.trade_date }}</td><td class="mono">{{ row.symbol }}</td><td>{{ row.name }}</td><td class="num">{{ row.close }}</td><td class="num">{{ row.change_pct }}</td><td class="num">{{ row.net_buy_amount }}</td><td class="num">{{ row.buy_amount }}</td><td class="num">{{ row.sell_amount }}</td><td class="num">{{ row.deal_amount }}</td><td class="num">{{ row.turnover_rate }}</td><td class="reason">{{ row.reason }}</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% else %}<div class="empty">No Dragon Tiger List rows were available for today&apos;s run.</div>{% endif %}
        </section>
      </div>

      <aside class="stack">
        <section class="panel">
          <div class="panel-head">
            <div class="panel-title"><h2>Run health</h2><span class="badge {{ data_source_kind }}">{{ data_source_status }}</span></div>
            <div class="panel-note">Operational signal</div>
          </div>
          <div class="panel-body">
            <p class="alert"><strong>Largest risk warning:</strong> {{ largest_risk_warning }}</p>
          </div>
        </section>

        <section id="excluded" class="panel">
          <div class="panel-head">
            <div class="panel-title"><h2>Excluded Stocks</h2><span class="badge warn">{{ excluded_count }}</span></div>
            <div class="panel-note">Data quality hard filters</div>
          </div>
          {% if excluded %}
          <div class="table-wrap">
            <table>
              <thead><tr><th>Symbol</th><th>Name</th><th>Reason</th><th>Last Date</th><th class="num">Avg Amount</th></tr></thead>
              <tbody>
                {% for row in excluded %}
                <tr><td class="mono">{{ row.symbol }}</td><td>{{ row.name }}</td><td class="reason">{{ row.exclude_reason }}</td><td>{{ row.last_price_date }}</td><td class="num">{{ row.avg_amount_20d }}</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% else %}<div class="empty">No stocks were excluded after data quality checks.</div>{% endif %}
        </section>

        <section id="holding-risk" class="panel">
          <div class="panel-head">
            <div class="panel-title"><h2>Holding Risk Review</h2><span class="badge warn">{{ holding_risk_count }}</span></div>
            <div class="panel-note">Manual review flags</div>
          </div>
          {% if holding_risk %}
          <div class="table-wrap">
            <table>
              <thead><tr><th>Symbol</th><th>Name</th><th class="num">Latest</th><th>Action</th><th>Reason</th></tr></thead>
              <tbody>
                {% for row in holding_risk %}
                <tr><td class="mono">{{ row.symbol }}</td><td>{{ row.name }}</td><td class="num">{{ row.latest_close }}</td><td><span class="badge {% if row.risk_action == 'WATCH' %}good{% else %}warn{% endif %}">{{ row.risk_action }}</span></td><td class="reason">{{ row.reason }}</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% else %}<div class="empty">No holding risk rows were generated for the current run.</div>{% endif %}
        </section>

        <section id="quality" class="panel">
          <div class="panel-head">
            <div class="panel-title"><h2>Data Quality Status</h2><span class="badge {{ data_source_kind }}">{{ data_source_status }}</span></div>
            <div class="panel-note">Machine-readable run status</div>
          </div>
          <pre>{{ data_quality_status }}</pre>
        </section>
      </aside>
    </div>
  </main>
</body>
</html>
